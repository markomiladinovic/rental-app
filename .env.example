# Admin credentials are stored in Supabase database (admins table, bcrypt hashed)
# REQUIRED — used to validate that login is configured. Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=change-this-to-a-random-string-in-production

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

RESEND_API_KEY=your-resend-api-key
ADMIN_EMAILS=admin1@email.com,admin2@email.com

# Secret for Vercel cron jobs (send-reminders endpoint)
CRON_SECRET=some-long-random-string

# Public site URL (used in sitemap, OG tags, JSON-LD). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://rental-app-kappa-flame.vercel.app
